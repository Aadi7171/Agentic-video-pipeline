# .env
# Agentic Video Pipeline Configuration

# VideoDB API Key (Get from console.videodb.io)
VIDEO_DB_API_KEY="your_videodb_api_key_here"

# Google Gemini API Key (Get from aistudio.google.com)
GEMINI_API_KEY="your_gemini_api_key_here"

# Pexels API Key for free stock videos (Get from pexels.com/api)
PEXELS_API_KEY="your_pexels_api_key_here"
